# Go
bin/
backend/vendor/
# Compiled adapter binary (built via `go build`/`go run` in the adapter dir)
adapters/custom-engine/custom-engine

# Proto generated code (regenerate with make proto)
backend/schema/*.go
adapters/panopticon/proto/
frontend/src/proto/

# SQLite
*.db
*.db-shm
*.db-wal
~/.usip/

# Node
frontend/node_modules/
frontend/dist/

# Env
.env
.env.local

# Local runner config (spawn-on-demand); commit runner_config.json.example instead
runner_config.json

# Python adapter artifacts
adapters/_proto/
**/__pycache__/
.venv/

# macOS
.DS_Store
